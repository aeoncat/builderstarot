generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  name                 String?
  email                String?         @unique
  emailVerified        DateTime?
  emailVerifiedBoolean Boolean         @default(false)
  image                String?
  passwordHash         String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  accounts             Account[]
  sessions             Session[]
  favorites            Favorite[]
  dailyDraws           DailyDraw[]
  journalEntries       JournalEntry[]
  spreadSessions       SpreadSession[]
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  type                  String?
  provider              String
  providerAccountId     String
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}

model Card {
  id                String             @id @default(cuid())
  name              String
  arcana            String
  suit              String?
  rank              String?
  keywords          String
  uprightMeaning    String
  reversedMeaning   String
  promptQuestions   String
  imageUrl          String?
  createdAt         DateTime           @default(now())
  journalEntryCards JournalEntryCard[]
  favorites         Favorite[]
  spreadCards       SpreadCard[]
  dailyDraws        DailyDraw[]

  @@index([arcana])
  @@index([suit])
  @@index([rank])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model DailyDraw {
  id          String   @id @default(cuid())
  userId      String
  cardId      String
  dateKey     String
  orientation String   @default("UPRIGHT")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}

model JournalEntry {
  id              String             @id @default(cuid())
  userId          String
  spreadType      String
  userNotes       String             @default("")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  spreadSessionId String?            @unique
  cards           JournalEntryCard[]
  spreadSession   SpreadSession?     @relation(fields: [spreadSessionId], references: [id], onDelete: SetNull)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model JournalEntryCard {
  id             String @id @default(cuid())
  journalEntryId String
  cardId         String
  positionName   String
  orientation    String
  sortOrder      Int

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([journalEntryId, sortOrder])
}

model SpreadSession {
  id           String        @id @default(cuid())
  spreadType   String
  createdAt    DateTime      @default(now())
  userId       String?
  cards        SpreadCard[]
  journalEntry JournalEntry?
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model SpreadCard {
  id           String @id @default(cuid())
  sessionId    String
  cardId       String
  positionName String
  orientation  String
  sortOrder    Int

  session SpreadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card    Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([sessionId, sortOrder])
}
